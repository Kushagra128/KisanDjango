# Kisan AI Django — Environment Variables
# Copy this file to .env and fill in your values.

# Required
DATABASE_URL=postgresql://user:password@localhost:5432/kisanai

# Django
DJANGO_SECRET_KEY=your-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ML settings
DISABLE_EMBEDDINGS=false          # set true to skip embedding model (keyword-only search)
CACHE_DIR=~/.cache/sentence_transformers

# Voice
VOSK_MODEL_PATH=                  # optional: override default search path
MAX_CONCURRENT_REQUESTS=10        # max simultaneous voice requests
